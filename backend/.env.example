OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=eleven_...
# Optional: pick a fast TTS model; you can switch to 'eleven_v3' if you want stronger [whispers] control
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# A default ElevenLabs voice id (from your dashboard); the "Adam" sample ID is common in docs:
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# CORS for local dev
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://localhost:3000
